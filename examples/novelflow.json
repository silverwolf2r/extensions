{
  "version": 1,
  "name": "NovelFlow (chapter-walk example)",
  "providers": [
    {
      "id": "novelflow",
      "name": "NovelFlow",
      "parser": "chapter-walk",
      "searchBases": ["https://www.novelflow.app"],
      "searchPaths": ["/search?q={query}"],
      "novelPathPattern": "/novel/",
      "chapterPath": "/chapters/{n}",
      "contentSelector": "non-paywall"
    }
  ]
}
